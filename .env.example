# ══════════════════════════════════════════════════════════════
# Design Hub — environment variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local for local dev; never commit .env.local.
# On Vercel, set the same variables via the project dashboard OR
#   npx vercel env add <NAME> <preview|production|development>
# scoped to each environment you deploy to.

# ── AI (required — without this, /api/chat and /api/builder/generate-content
#    fail and the builder renders an "AI features are off" banner) ──
ANTHROPIC_API_KEY=

# ── Firebase (client-side; drives session persistence + auto-save.
#    If absent, Firebase initializes silently no-op and session state
#    is in-memory only.) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Rate limiting (optional; code falls back to unlimited if absent).
#    Upstash is the Vercel Marketplace integration; KV is the legacy
#    Vercel KV fallback. Either pair works. ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── Staging auth middleware (optional; only set if you want the app
#    to enforce basic-auth at the middleware layer. Vercel project-level
#    password protection usually covers this for previews already.) ──
# STAGING_USER=
# STAGING_PASSWORD=
# STAGING_TOKEN_SECRET=
# ADMIN_IPS=

# ── Analytics (optional) ──
# NEXT_PUBLIC_GA_ID=
