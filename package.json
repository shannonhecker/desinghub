{
  "name": "design-hub",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "defaults",
    "Safari >= 15.4"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "tokens:audit": "node scripts/tokens-audit.mjs",
    "tokens:audit:write": "node scripts/tokens-audit.mjs --write",
    "tokens:audit:json": "node scripts/tokens-audit.mjs --json",
    "carbon:scoped-css": "node scripts/generate-carbon-scoped-css.mjs",
    "ss": "node scripts/screenshot-matrix.mjs",
    "ss:baseline": "node scripts/screenshot-matrix.mjs --save",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@carbon/icons-react": "^11.78.0",
    "@carbon/react": "^1.108.0",
    "@carbon/styles": "^1.107.0",
    "@carbon/themes": "^11.74.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@floating-ui/react": "^0.27.19",
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-theme": "^9.2.1",
    "@mui/material": "^9.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@salt-ds/core": "^1.63.0",
    "@salt-ds/theme": "^1.43.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/three": "^0.183.1",
    "@upstash/redis": "^1.37.0",
    "ag-grid-community": "^35.2.1",
    "ag-grid-react": "^35.2.1",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "gsap": "^3.15.0",
    "highcharts": "^12.5.0",
    "highcharts-react-official": "^3.2.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.31",
    "typescript": "^5",
    "vercel": "^51.8.0",
    "vitest": "^4.1.4"
  }
}
