rules_version = '2';

// Design Hub — Firestore security rules.
// Access pattern (see src/lib/firebase.ts): a single `projects` collection,
// every doc carries a `uid` field, written under anonymous auth and queried
// with `where("uid","==",request.auth.uid)`. Each user may touch only their
// own project docs.
service cloud.firestore {
  match /databases/{database}/documents {

    match /projects/{projectId} {
      // Read / modify / remove only docs you own.
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;

      // Create only a doc stamped with your own uid.
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Everything else: denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
